# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Grafana UI overlay, generated by `make grafana-ui` (the fork's built public/)
/resources/grafana-public/

# Compute sidecar externalBin, staged by `make compute-sidecar-stage`
/binaries/

# runtime per-(plugin,org) secret store (never commit)
secrets/
