# Generated by Cargo
# will have compiled files and executables
/target/

# Generated by Tauri
# will have schema files for capabilities auto-completion
/gen/schemas

# Grafana UI overlay, generated by `make grafana-ui` (the fork's built public/)
/resources/grafana-public/

# Compute + Go service sidecars (externalBin), staged by `make compute-sidecar-stage` / `make dataplane-stage`
/binaries/

# Data-plane tree resource, staged by `make dataplane-stage` (copy of /dataplane)
/resources/dataplane/

# Bundled artifact tarballs (Postgres/RisingWave/Grafana), staged by `make artifacts-stage`
/resources/artifacts/

# runtime per-(plugin,org) secret store (never commit)
secrets/
